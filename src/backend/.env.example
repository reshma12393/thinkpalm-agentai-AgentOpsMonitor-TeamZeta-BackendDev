# Copy to .env and fill in. Do not commit .env.
# Run uvicorn from the backend/ directory so this file is loaded.
#
# LLM: OpenRouter (https://openrouter.ai/keys) — OpenAI-compatible API.

OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Cap tokens — avoids OpenRouter reserving the model default (e.g. 64k) which can trigger 402 on low credits:
# OPENROUTER_MAX_OUTPUT_TOKENS=2048
# Truncate JSON/text blobs in prompts (input savings):
# OPENROUTER_MAX_LLM_INPUT_CHARS=10000
# Optional attribution (recommended by OpenRouter):
# OPENROUTER_HTTP_REFERER=http://localhost:5173
# OPENROUTER_APP_TITLE=AutoML Debate System
